function computeSchedulerNextRunAt(scheduler) {
    if (!schedulerLib || !scheduler || !scheduler.enabled || !scheduler.startTime) return null
    try {
        return schedulerLib.getNextScheduledRun(scheduler).target.toISOString()
    } catch {
