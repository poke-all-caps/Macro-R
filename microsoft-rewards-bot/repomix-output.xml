      if (v === 'manage') {
        G('lic-manage-plan').textContent = _coreData.planType || 'Premium';
        G('lic-manage-expires').textContent = _coreData.expiresAt
          ? 'Expires ' + new Date(_coreData.expiresAt).toLocaleDateString()
