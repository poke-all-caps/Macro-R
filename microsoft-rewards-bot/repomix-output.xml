            } else { var msg = await r.text(); alert('Could not save settings: ' + (msg || 'Unknown error')); }
          } catch(err) { alert('Save failed: ' + err.message); }
          finally { if (saveBtn) { saveBtn.disabled = false; saveBtn.textContent = 'Save settings'; } }
