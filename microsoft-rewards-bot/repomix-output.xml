    .csell-strip-lbl{font-size:11.5px;color:var(--muted);margin-top:6px;font-weight:600;line-height:1.35}
    @media (max-width:680px){.csell-strip{grid-template-columns:repeat(2,1fr)}}
    /* Comparison table */
